#include <stdio.h>

struct Item {
    int value;
    int weight;
};

void swap(struct Item *a, struct Item *b) {
    struct Item temp = *a;
    *a = *b;
    *b = temp;
}

void sort(struct Item arr[], int n) {
    int i, j;
    for (i = 0; i < n - 1; i++) {
        for (j = 0; j < n - i - 1; j++) {
            float r1 = (float)arr[j].value / arr[j].weight;
            float r2 = (float)arr[j + 1].value / arr[j + 1].weight;

            if (r1 < r2) {
                swap(&arr[j], &arr[j + 1]);
            }
        }
    }
}

float knapsack(struct Item arr[], int n, int capacity) {
    sort(arr, n);

    float totalValue = 0.0;

    for (int i = 0; i < n; i++) {
        if (capacity >= arr[i].weight) {
            capacity -= arr[i].weight;
            totalValue += arr[i].value;
        } else {
            totalValue += arr[i].value * ((float)capacity / arr[i].weight);
            break;
        }
    }

    return totalValue;
}

int main() {
    struct Item arr[] = {{60, 10}, {100, 20}, {120, 30}};
    int n = sizeof(arr) / sizeof(arr[0]);
    int capacity = 50;

    printf("Maximum value in Knapsack = %.2f\n", knapsack(arr, n, capacity));

    return 0;
}
